# --- DeepCodonOpt ---

# Local-only originals and raw experiment outputs (archived to Zenodo, not committed)
_legacy/
_result/

# Datasets & genomes (download / build with build_dataset.py — see README)
data/
*.jsonl
*.fna
*.faa
*.gbff
*.gz

# Model checkpoints (large -> Zenodo)
*.ckpt
*.pt
*.bin
*.safetensors

# Generated outputs / figures (regenerate with make_report_figs.py)
results/
output/
report_figs/
*.png
*.svg

# IDT credentials / tokens (never commit secrets)
credentials*.json
*idt*token*
.env

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.pdf
paper/*.synctex.gz
paper/figs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# OS / editor
.DS_Store
.idea/
.vscode/
